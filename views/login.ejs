<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
</head>
<body>
  <h1>Login</h1>
  <% if (error) { %>
    <p style="color:red"><%= error %></p>
  <% } %>
  <form action="/auth/start" method="post">
    <label for="email">Work email</label>
    <input id="email" name="email" type="email" placeholder="name@company.com" required />
    <button type="submit">Continue with SSO</button>
  </form>
  <% if (!oidcConfigured) { %>
    <p>OIDC routing will stay unavailable until <code>OIDC_CLIENT_ID</code> and <code>OIDC_CLIENT_SECRET</code> are configured.</p>
  <% } %>
  <p>The app chooses SAML or OIDC only from the email domain rules in <code>config.js</code>.</p>
</body>
</html>
